# Licence copies placed into each publishable package at build time by
# scripts/copy-license.mjs — npm packs only what is inside a package
# directory, so the files have to exist there, but the originals at the repo
# root are the source of truth and these are refreshed on every build.
packages/*/LICENSE
packages/*/LICENSE-COMMERCIAL.md

# VitePress build output and cache
packages/docs/.vitepress/dist
packages/docs/.vitepress/cache
