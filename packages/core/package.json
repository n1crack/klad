{
  "name": "@klad/engine",
  "version": "1.1.0",
  "description": "Layout, viewport maths, spatial index, canvas renderer and worker protocol for Klad. No DOM.",
  "keywords": [
    "org-chart",
    "orgchart",
    "organization-chart",
    "tree",
    "hierarchy",
    "canvas",
    "klad",
    "layout",
    "tidy-tree"
  ],
  "homepage": "https://klad.ozdemir.be",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/n1crack/klad.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/n1crack/klad/issues"
  },
  "author": "Yusuf Özdemir",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./host": {
      "types": "./src/worker/host.ts",
      "import": "./src/worker/host.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./host": {
        "types": "./dist/worker/host.d.ts",
        "import": "./dist/worker/host.js"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "LICENSE-COMMERCIAL.md"
  ],
  "scripts": {
    "build": "node ../../scripts/copy-license.mjs && tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.browser-test.json && tsc --noEmit -p tsconfig.worker.json"
  }
}
