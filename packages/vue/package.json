{
  "name": "@n1crack/orgchart-vue",
  "version": "1.0.0-alpha.0",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "sideEffects": false,
  "//": "exports point at source during development so the workspace resolves without a build step; publishConfig.exports replaces them with the built dist paths at publish time.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": ["dist", "LICENSE", "LICENSE-COMMERCIAL.md"],
  "dependencies": {
    "@n1crack/orgchart": "workspace:*"
  },
  "peerDependencies": {
    "vue": ">=3.5 <4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^3.3.0"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json"
  }
}
