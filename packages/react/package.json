{
  "name": "@klad/react",
  "version": "1.1.0",
  "description": "React adapter for Klad — <Klad> with a render prop and a ref handle.",
  "keywords": [
    "org-chart",
    "orgchart",
    "organization-chart",
    "tree",
    "hierarchy",
    "canvas",
    "klad",
    "react"
  ],
  "homepage": "https://klad.ozdemir.be",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/n1crack/klad.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/n1crack/klad/issues"
  },
  "author": "Yusuf Özdemir",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "sideEffects": false,
  "exports": {
