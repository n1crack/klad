      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "LICENSE-COMMERCIAL.md"
  ],
  "dependencies": {
    "@klad/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "react": "^19.2.8",
    "react-dom": "^19.2.8"
  },
  "scripts": {
    "build": "node ../../scripts/copy-license.mjs && tsdown",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  }
