{
  "name": "klad-monorepo",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "pnpm --filter @klad/playground dev",
    "docs": "pnpm --filter @klad/docs dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "check:packages": "turbo run build && node scripts/check-packages.mjs",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint packages",
    "format": "prettier --write \"packages/**/*.{ts,vue,json,md}\"",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install --lockfile-only"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@changesets/cli": "^2.31.1",
    "@types/node": "^22.20.1",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "4.1.10",
    "oxlint": "^1.75.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.6",
    "publint": "^0.3.22",
    "tsdown": "^0.22.14",
    "turbo": "^2.10.6",
    "typescript": "5.9.3",
    "vitest": "^4.1.10"
  }
}
